# ─────────────────────────────────────────────────
#  .env — Agendamento System
#  Copie este arquivo para .env e preencha os valores
#  NUNCA commite o .env no GitHub (já está no .gitignore)
# ─────────────────────────────────────────────────

# Porta local de desenvolvimento (Railway define automaticamente)
PORT=3000

# URL de deploy do Google Apps Script
# Exemplo: https://script.google.com/macros/s/AKfycb.../exec
GAS_DEPLOY_URL=https://script.google.com/macros/s/SEU_DEPLOY_ID/exec

# Chave secreta para autenticação das chamadas API (mesmo valor em GAS PropertiesService)
# No GAS: PropertiesService.getScriptProperties().setProperty('API_KEY', 'sua-chave-aqui')
GAS_API_KEY=sua-chave-secreta-aqui

# Proteção da aplicação interna. Use valor aleatório com 32+ caracteres.
SESSION_SECRET=troque-por-um-segredo-de-assinatura-forte
SESSION_TTL_HOURS=12
ALLOWED_ORIGINS=https://sistema.oticastgt.com.br,https://sistema-production-cd20.up.railway.app

# Kommo / Salesbot
KOMMO_SUBDOMAIN=oticastargetcontato
KOMMO_ACCESS_TOKEN=cole-o-token-de-acesso-do-kommo
KOMMO_USE_SALESBOT=true
BOT_ENABLED=true
SALESBOT_SECRET=gere-um-segredo-forte-para-o-salesbot
KOMMO_WEBHOOK_SECRET=gere-um-segredo-forte-para-o-webhook

# Mapa de estagios por pipeline — gerado pelo endpoint POST /api/admin/kommo/setup-stages
# Cole o valor retornado pelo endpoint no campo env_var
KOMMO_STAGES_MAP={}

# (Opcional) Timeout em minutos antes do bot retomar controle apos atendente humano
BOT_HUMAN_TIMEOUT_MIN=5
BOT_HUMAN_RESUME_MIN=60

# (Legado) Estagios individuais — use KOMMO_STAGES_MAP no lugar
KOMMO_STAGE_AGENDAR=
KOMMO_DEFAULT_RESPONSIBLE_ID=
